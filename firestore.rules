rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /blogs/{blogId} {
      allow read: if true;

      allow create: if isSignedIn()
        && hasRequiredBlogFieldsOnCreate()
        && isCreatingOwnAuthorId();

      allow update: if isSignedIn()
        && isOwner()
        && hasRequiredBlogFieldsOnUpdate()
        && isUpdatingOwnAuthorId();

      allow delete: if isSignedIn() && isOwner();

      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner() {
        return resource.data.authorId == request.auth.uid
          || (
            resource.data.author is map
            && resource.data.author.email is string
            && request.auth.token.email is string
            && resource.data.author.email == request.auth.token.email
          );
      }

      function isCreatingOwnAuthorId() {
        return request.resource.data.authorId == request.auth.uid;
      }

      function isUpdatingOwnAuthorId() {
        return request.resource.data.authorId == request.auth.uid;
      }

      function hasRequiredBlogFieldsOnCreate() {
        return request.resource.data.keys().hasOnly([
            'id',
            'authorId',
            'title',
            'excerpt',
            'content',
            'coverImage',
            'category',
            'author',
            'createdAt',
            'updatedAt'
          ])
          && request.resource.data.id is string
          && request.resource.data.authorId is string
          && request.resource.data.title is string
          && request.resource.data.excerpt is string
          && request.resource.data.content is string
          && request.resource.data.coverImage is string
          && request.resource.data.category is string
          && request.resource.data.author is map
          && request.resource.data.author.keys().hasOnly(['name', 'email'])
          && request.resource.data.author.name is string
          && request.resource.data.author.email is string
          && request.resource.data.createdAt is timestamp
          && request.resource.data.updatedAt is timestamp;
      }

      function hasRequiredBlogFieldsOnUpdate() {
        return hasRequiredBlogFieldsOnCreate()
          && request.resource.data.id == resource.data.id
          && request.resource.data.authorId == resource.data.authorId
          && request.resource.data.createdAt == resource.data.createdAt;
      }
    }
  }
}
